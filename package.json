{
  "name": "brine",
  "version": "3.0.0",
  "description": "Feedi - federated blog + RSS reader",
  "type": "module",
  "author": "brine",
  "license": "AGPL",
  "main": "app.js",
  "standard": {
    "env": [
      "browser"
    ]
  },
  "scripts": {
    "test": "node --test --test-reporter spec test/unit/*.test.js",
    "test:unit": "node --test --test-reporter spec test/unit/*.test.js",
    "test:e2e": "start-server-and-test \"npx wrangler dev --env dev\" http://localhost:8787 \"node --test --test-concurrency=4 --test-reporter spec test/e2e/*.test.js\"",
    "test:debug": "HEADLESS=0 SLOWMO=100 start-server-and-test \"npx wrangler dev --env dev\" http://localhost:8787 \"node --test --test-reporter spec test/e2e/*.test.js\"",
    "kill": "pkill -f chromium",
    "purge": "curl -X POST \"https://api.cloudflare.com/client/v4/zones/$BRINE_TOKEN/purge_cache\" -H \"Authorization: Bearer $BEARER\" -H \"Content-Type: application/json\" --data '{\"purge_everything\":true}'",
    "feeds:refresh": "npm run purge && curl -s -X POST \"https://feedi.brine.dev/feeds/refresh?secret=$ADMIN_SECRET\"",
    "pretty": "npx standard --fix"
  },
  "devDependencies": {
    "puppeteer": "^24.3.1",
    "sirv-cli": "^3.0.0",
    "start-server-and-test": "^2.0.12"
  },
  "dependencies": {
    "marked": "^15.0.12"
  }
}
